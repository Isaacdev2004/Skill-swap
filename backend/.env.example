# Server
NODE_ENV=development
PORT=5000
API_VERSION=v1

# MongoDB
MONGODB_URI=mongodb://localhost:27017/skillswap
# Use true for local dev when MongoDB/Docker is not installed
USE_MEMORY_DB=false

# Redis (optional — graceful fallback when unavailable)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cookies
COOKIE_SECRET=change-me-cookie-secret-min-32-chars

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:21899

# Email (Nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=SkillSwap <noreply@skillswap.app>

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Admin seed credentials
SEED_ADMIN_EMAIL=admin@skillswap.app
SEED_ADMIN_PASSWORD=Admin123!@#
