    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.18.6",
    "@types/nodemailer": "^7.0.1",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^30.1.3",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
